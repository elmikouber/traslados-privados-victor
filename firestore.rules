rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function invitacionResenaValida(token, telefono, refSolicitud) {
      return exists(/databases/$(database)/documents/invitaciones_resena/$(token))
        && get(/databases/$(database)/documents/invitaciones_resena/$(token)).data.usado == false
        && get(/databases/$(database)/documents/invitaciones_resena/$(token)).data.telefono == telefono
        && get(/databases/$(database)/documents/invitaciones_resena/$(token)).data.refSolicitud == refSolicitud;
    }

    function actualizacionCotizacionCliente() {
      let token = request.resource.data.get('confirmacionToken', '');
      let estadoNuevo = request.resource.data.estado;
      return resource.data.estado == 'cotizacion_pendiente'
        && resource.data.tokenConfirmacion == token
        && token.size() >= 16
        && estadoNuevo in ['confirmado', 'rechazado', 'cancelado']
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['estado', 'updatedAt', 'cliente', 'politicas', 'confirmacionToken']);
    }

    function actualizacionSlotCotizacionCliente() {
      return resource.data.estado == 'cotizacion_pendiente'
        && request.resource.data.estado in ['confirmado', 'cancelado']
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['estado', 'updatedAt']);
    }

    match /solicitudes/{id} {
      allow create: if true;
      allow read, update: if request.auth != null || actualizacionCotizacionCliente();
      allow delete: if false;
    }

    match /confirmaciones_cotizacion/{token} {
      allow get: if true;
      allow list: if false;
      allow create: if request.auth != null;
      allow update: if request.auth != null
        || (
          resource.data.estado == 'pendiente'
          && request.resource.data.estado in ['aceptada', 'rechazada', 'expirada']
          && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['estado', 'respondedAt', 'clienteComplemento'])
        );
      allow delete: if false;
    }

    match /invitaciones_resena/{token} {
      allow create: if request.auth != null;
      allow get: if true;
      allow list: if false;
      allow update: if resource.data.usado == false
        && request.resource.data.usado == true
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['usado', 'usadoAt']);
      allow delete: if false;
    }

    match /resenas/{resenaId} {
      allow get: if !exists(/databases/$(database)/documents/resenas/$(resenaId))
        || resource.data.estado == "aprobada"
        || request.auth != null;
      allow list: if resource.data.estado == "aprobada" || request.auth != null;
      allow create: if request.resource.data.estado == "pendiente"
        && request.resource.data.refSolicitud == resenaId
        && request.resource.data.token is string
        && request.resource.data.telefono is string
        && request.resource.data.telefono.size() >= 10
        && !exists(/databases/$(database)/documents/resenas/$(resenaId))
        && invitacionResenaValida(
          request.resource.data.token,
          request.resource.data.telefono,
          resenaId
        );
      allow update: if request.auth != null;
      allow delete: if false;
    }

    match /historial_por_telefono/{telefono} {
      allow read, write: if request.auth != null;
    }

    match /historial_clientes/{token} {
      allow get: if true;
      allow list: if false;
      allow create, update: if request.auth != null;
      allow delete: if false;

      match /viajes/{viajeId} {
        allow get, list: if true;
        allow create, update: if request.auth != null;
        allow delete: if false;
      }
    }

    match /disponibilidad/{fecha} {
      allow read: if true;

      match /slots/{slotId} {
        allow read: if true;
        allow create: if (
          request.auth != null
          && slotId == request.resource.data.ref
          && request.resource.data.fecha == fecha
          && request.resource.data.estado in ["pendiente", "cotizacion_pendiente"]
          && request.resource.data.horario is string
          && request.resource.data.horario.matches('^[0-9]{2}:[0-9]{2}$')
          && request.resource.data.minutos is number
          && request.resource.data.minutos >= 30
          && request.resource.data.minutos <= 720
          && request.resource.data.tipo in ["traslado", "tour"]
        ) || (
          slotId == request.resource.data.ref
          && request.resource.data.fecha == fecha
          && request.resource.data.estado == "pendiente"
          && request.resource.data.horario is string
          && request.resource.data.horario.matches('^[0-9]{2}:[0-9]{2}$')
          && request.resource.data.minutos is number
          && request.resource.data.minutos >= 30
          && request.resource.data.minutos <= 720
          && request.resource.data.tipo in ["traslado", "tour"]
        );
        allow update, delete: if request.auth != null
          || actualizacionSlotCotizacionCliente();
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }

  }
}
